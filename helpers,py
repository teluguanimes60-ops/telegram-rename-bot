import os
import re

def clean_filename(name):
    name = re.sub(r'[\\/*?:"<>|]', "", name)
    return name.strip()


def format_size(size):
    return round(size / (1024 * 1024), 2)


def safe_remove(path):
    try:
        if os.path.exists(path):
            os.remove(path)
    except:
        pass
